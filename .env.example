# Copy to .env (gitignored) and fill in — or let `make docker-setup` write it
# for you (it prompts for and validates every value below).

# GitHub token. A PAT with `repo` scope, or `gh auth token` output. Used for
# both the GitHub API and raw `git push` (the entrypoint runs gh auth setup-git).
GH_TOKEN=ghp_...
GITHUB_TOKEN=ghp_...          # same value; some tools read one or the other

# KeySmith credentials for Bedrock access (https://keysmith.int.tubi.io/docs).
# Create an API key on the "My Keys" page; the secret is shown only once.
KEYSMITH_URL=https://keysmith.int.tubi.io
KEYSMITH_KEY_ID=01J...        # ULID shown after key creation
KEYSMITH_SECRET=btv_...       # full secret (shown only once)
