{
  "name": "@babysit/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "cp -R src/overview-assets dist/overview-assets",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts",
    "poll-once": "tsx src/cli.ts poll-once",
    "list-prs": "tsx src/cli.ts list-prs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.193",
    "@excalidraw/utils": "^0.1.3-test32",
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^11.8.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "node-notifier": "^10.0.1",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-notifier": "^8.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
